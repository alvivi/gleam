package thepackage

func Go(x int64) int64 {
  return (func() int64 {
    _case_subject := x
    _ = _case_subject
    if _case_subject == int64(0) {
      return int64(100)
    }
    if _case_subject == int64(1) {
      return int64(200)
    }
    return int64(999)
  }())
}
