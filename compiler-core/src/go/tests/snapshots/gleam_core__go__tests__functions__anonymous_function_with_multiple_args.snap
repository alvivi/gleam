pub fn go() -> Int {
  let add = fn(a: Int, b: Int) -> Int { a + b }
  add(3, 4)
}


----- COMPILED GO
package thepackage

func Go() int64 {
  add := func(a int64, b int64) int64 {
    return (a + b)
  }
  _ = add
  return add(int64(3), int64(4))
}
