----- SOURCE CODE

fn double(x: Int) -> Int {
  x * 2
}

fn apply(f: fn(Int) -> Int, x: Int) -> Int {
  f(x)
}

pub fn go() -> Int {
  apply(double, 5)
}


----- COMPILED GO
package thepackage

func double(x int64) int64 {
  return (x * int64(2))
}

func apply(f func(int64) int64, x int64) int64 {
  return f(x)
}

func Go() int64 {
  return apply(double, int64(5))
}
