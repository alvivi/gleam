----- SOURCE CODE

fn apply(f: fn(Int) -> Int, x: Int) -> Int {
  f(x)
}

pub fn go() -> Int {
  apply(fn(x: Int) -> Int { x + 100 }, 1)
}


----- COMPILED GO
package thepackage

func apply(f func(int64) int64, x int64) int64 {
  return f(x)
}

func Go() int64 {
  return apply(func(x int64) int64 {
    return (x + int64(100))
  }, int64(1))
}
