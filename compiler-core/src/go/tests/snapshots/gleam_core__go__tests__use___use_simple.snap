fn with_int(callback: fn(Int) -> Int) -> Int {
  callback(5)
}

pub fn go() -> Int {
  use n <- with_int
  n + 1
}


----- COMPILED GO
package thepackage

func withInt(callback func(int64) int64) int64 {
  return callback(int64(5))
}

func Go() int64 {
  return withInt(func(n int64) int64 {
    return (n + int64(1))
  })
