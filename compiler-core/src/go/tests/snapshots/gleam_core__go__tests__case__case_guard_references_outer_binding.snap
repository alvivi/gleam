pub fn go(x: Int, threshold: Int) -> Int {
  case x {
    n if n > threshold -> 1
    _ -> 0
  }
}


----- COMPILED GO
package thepackage

func Go(x int64, threshold int64) int64 {
  return (func() int64 {
    _case_subject := x
    _ = _case_subject
    n := _case_subject
    _ = n
    if (n > threshold) {
      return int64(1)
    }
    return int64(0)
  }())
}
