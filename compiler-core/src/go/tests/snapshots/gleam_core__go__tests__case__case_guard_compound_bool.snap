func Go(x int64) int64 {
  return (func() int64 {
    _case_subject := x
    _ = _case_subject
    n := _case_subject
    _ = n
    if ((n > int64(0)) && (n < int64(10))) {
      return n
    }
    return int64(-1)
  }())
}
