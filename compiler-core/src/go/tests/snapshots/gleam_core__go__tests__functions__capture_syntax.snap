----- SOURCE CODE

fn add(a: Int, b: Int) -> Int {
  a + b
}

pub fn go() -> Int {
  let inc = add(_, 1)
  inc(41)
}


----- COMPILED GO
package thepackage

func add(a int64, b int64) int64 {
  return (a + b)
}

func Go() int64 {
  inc := func(_capture int64) int64 {
    return add(_capture, int64(1))
  }
  _ = inc
  return inc(int64(41))
}
