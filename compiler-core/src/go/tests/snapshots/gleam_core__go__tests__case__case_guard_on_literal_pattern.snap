package thepackage

func Go(x int64, y int64) int64 {
  return (func() int64 {
    _case_subject := x
    _ = _case_subject
    if _case_subject == int64(0) {
      if (y > int64(0)) {
        return int64(1)
      }
    }
    if _case_subject == int64(0) {
      return int64(2)
    }
    return int64(3)
  }())
