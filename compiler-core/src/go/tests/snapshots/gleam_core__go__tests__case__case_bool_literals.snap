package thepackage

func Go(x bool) int64 {
  return (func() int64 {
    _case_subject := x
    _ = _case_subject
    if _case_subject == true {
      return int64(1)
    }
    if _case_subject == false {
      return int64(0)
    }
    panic("non-exhaustive case")
  }())
}
