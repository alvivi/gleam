----- SOURCE CODE

fn with_a(callback: fn(Int) -> Int) -> Int {
  callback(1)
}

fn with_b(callback: fn(Int) -> Int) -> Int {
  callback(2)
}

pub fn go() -> Int {
  use a <- with_a
  use b <- with_b
  a + b
}


