package thepackage

func withA(callback func(int64) int64) int64 {
  return callback(int64(1))
}

func withB(callback func(int64) int64) int64 {
  return callback(int64(2))
}

func Go() int64 {
  return withA(func(a int64) int64 {
    return withB(func(b int64) int64 {
      return (a + b)
    })
  })
}
