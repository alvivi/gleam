----- SOURCE CODE

pub fn go(x: Int, y: Int) -> Int {
  case x + y {
    0 -> 1
    _ -> 2
  }
}


----- COMPILED GO
package thepackage

func Go(x int64, y int64) int64 {
  return (func() int64 {
    _case_subject := (x + y)
    _ = _case_subject
    if _case_subject == int64(0) {
      return int64(1)
    }
    return int64(2)
  }())
}
